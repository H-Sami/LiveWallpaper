<UserControl x:Class="LiveWallpaper.Controller.Controls.RangeSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:LiveWallpaper.Controller.Controls"
        Height="48" MinWidth="240">
    <UserControl.Resources>
        <ControlTemplate x:Key="StartThumbTemplate" TargetType="primitives:Thumb">
            <Grid>
                <Ellipse x:Name="Ring" Fill="{StaticResource SurfaceBrush}" Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter TargetName="Ring" Property="Stroke" Value="White" />
                    <Setter TargetName="Ring" Property="StrokeThickness" Value="3" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <ControlTemplate x:Key="EndThumbTemplate" TargetType="primitives:Thumb">
            <Grid>
                <Ellipse x:Name="Ring" Fill="{StaticResource SurfaceBrush}" Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter TargetName="Ring" Property="Stroke" Value="White" />
                    <Setter TargetName="Ring" Property="StrokeThickness" Value="3" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    <Canvas x:Name="Surface" Background="Transparent" MouseLeftButtonDown="Surface_MouseLeftButtonDown">
        <Border x:Name="BaseTrack" Height="4" CornerRadius="2" Background="#303033" Canvas.Top="22" />
        <Border x:Name="SelectedTrack" Height="4" CornerRadius="2" Background="{StaticResource AccentBrush}" Canvas.Top="22" />
        <controls:RangeThumb x:Name="StartThumb" Width="24" Height="24" Canvas.Top="12"
                          Focusable="True" AutomationProperties.Name="Segment start"
                          Template="{StaticResource StartThumbTemplate}"
                          DragDelta="StartThumb_DragDelta" KeyDown="StartThumb_KeyDown" />
        <controls:RangeThumb x:Name="EndThumb" Width="24" Height="24" Canvas.Top="12"
                          Focusable="True" AutomationProperties.Name="Segment end"
                          Template="{StaticResource EndThumbTemplate}"
                          DragDelta="EndThumb_DragDelta" KeyDown="EndThumb_KeyDown" />
    </Canvas>
</UserControl>
