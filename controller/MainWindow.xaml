<Window x:Class="LiveWallpaper.Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:LiveWallpaper.Controller.Controls"
        Title="LiveWallpaper" Width="1180" Height="760" MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}" AllowsTransparency="False" Icon="Assets/LiveWallpaper.ico"
        FontFamily="{StaticResource UiFont}" FontSize="14" SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="7" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVisibility" />
    </Window.Resources>

    <Border x:Name="WindowFrame" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Deliberately plain, native-feeling title bar. -->
            <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" MouseRightButtonUp="TitleBar_MouseRightButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="46" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0"
                                IsHitTestVisible="False" Focusable="False" AutomationProperties.Name="">
                        <Image Source="Assets/LiveWallpaper.png" Width="26" Height="26" Margin="0,0,10,0"
                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="LiveWallpaper" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            Click="MinimizeButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            AutomationProperties.Name="Minimize">
                        <Path Data="M 0,0.5 L 10,0.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Width="10" Height="1" SnapsToDevicePixels="True" />
                    </Button>
                    <Button Grid.Column="2" x:Name="MaximizeButton" Style="{StaticResource CaptionButton}"
                            Click="MaximizeButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            AutomationProperties.Name="Maximize">
                        <Grid Width="12" Height="12">
                            <Path x:Name="MaximizeGlyph" Data="M 0.5,0.5 L 10.5,0.5 L 10.5,10.5 L 0.5,10.5 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1" SnapsToDevicePixels="True" />
                            <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                <Path Data="M 3.5,0.5 L 10.5,0.5 L 10.5,7.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                                <Path Data="M 0.5,3.5 L 7.5,3.5 L 7.5,10.5 L 0.5,10.5 Z" Fill="{StaticResource ChromeBrush}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                            </Grid>
                        </Grid>
                    </Button>
                    <Button Grid.Column="3" x:Name="CloseButton" Style="{StaticResource CloseCaptionButton}"
                            Click="CloseButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            AutomationProperties.Name="Close">
                        <Path Data="M 0.5,0.5 L 10.5,10.5 M 10.5,0.5 L 0.5,10.5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Width="11" Height="11" SnapsToDevicePixels="True" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="204" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="12,20,12,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="WorkspaceLabel" Text="WORKSPACE" Foreground="{StaticResource SubtleBrush}"
                                       FontSize="10" FontWeight="SemiBold" Margin="12,0,0,8" />
                            <Button x:Name="LibraryNav" Style="{StaticResource NavButton}" Click="LibraryNav_Click" Margin="0,0,0,3" AutomationProperties.Name="Library">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="0,0,11,0"><Path Data="M1,1 H7 V7 H1 Z M10,1 H16 V7 H10 Z M1,10 H7 V16 H1 Z M10,10 H16 V16 H10 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.4" /></Viewbox>
                                    <TextBlock x:Name="LibraryNavLabel" Text="Library" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="EditorNav" Style="{StaticResource NavButton}" Click="EditorNav_Click" Margin="0,0,0,3" AutomationProperties.Name="Editor">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="0,0,11,0"><Path Data="M2,14 L2,17 L5,17 L15.8,6.2 L12.8,3.2 Z M11.8,4.2 L14.8,7.2 M7,17 H17" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.4" StrokeLineJoin="Round" /></Viewbox>
                                    <TextBlock x:Name="EditorNavLabel" Text="Editor" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Click="SettingsNav_Click" AutomationProperties.Name="Settings">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="0,0,11,0"><Path Data="M9,1.5 A2,2 0 0 1 11,3.5 L11.3,4.4 A6,6 0 0 1 12.7,5.2 L13.6,4.9 A2,2 0 0 1 16.1,6.3 A2,2 0 0 1 15.6,9 L14.9,9.6 A6,6 0 0 1 14.9,11.2 L15.6,11.8 A2,2 0 0 1 16.1,14.5 A2,2 0 0 1 13.6,15.9 L12.7,15.6 A6,6 0 0 1 11.3,16.4 L11,17.3 A2,2 0 0 1 7,17.3 L6.7,16.4 A6,6 0 0 1 5.3,15.6 L4.4,15.9 A2,2 0 0 1 1.9,14.5 A2,2 0 0 1 2.4,11.8 L3.1,11.2 A6,6 0 0 1 3.1,9.6 L2.4,9 A2,2 0 0 1 1.9,6.3 A2,2 0 0 1 4.4,4.9 L5.3,5.2 A6,6 0 0 1 6.7,4.4 L7,3.5 A2,2 0 0 1 9,1.5 Z M9,7 A3,3 0 1 0 9,13 A3,3 0 1 0 9,7" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Fill="Transparent" /></Viewbox>
                                    <TextBlock x:Name="SettingsNavLabel" Text="Settings" VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border x:Name="HostStatusCard" Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" CornerRadius="7">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="HostDot" Width="7" Height="7" Fill="{StaticResource SubtleBrush}" Margin="0,0,8,0" />
                                    <TextBlock x:Name="HostStateText" Text="Host stopped" FontSize="12" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="Wallpaper playback continues when this window is closed."
                                           Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,7,0,0" LineHeight="16" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <!-- Library -->
                    <Grid x:Name="LibraryPage" Margin="32,28,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Wallpaper library" FontSize="27" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Style="{StaticResource AccentButton}" Click="AddWallpaper_Click" AutomationProperties.Name="Add wallpaper">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M6,0 V12 M0,6 H12" Stroke="#111112" StrokeThickness="1.5" Width="12" Height="12" Margin="0,0,8,0" />
                                    <TextBlock Text="Add wallpaper" Foreground="#111112" FontSize="13" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,24,0,18">
                            <TextBox x:Name="SearchBox" Width="310" HorizontalAlignment="Left" TextChanged="SearchBox_TextChanged" AutomationProperties.Name="Search wallpapers" />
                            <TextBlock Text="Search by filename…" Foreground="{StaticResource SubtleBrush}" Margin="13,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" x:Name="SearchHint" FontSize="13" />
                            <TextBlock x:Name="LibraryCountText" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                        </Grid>

                        <Grid Grid.Row="2">
                            <ScrollViewer Style="{StaticResource InvisibleScrollViewer}" AutomationProperties.Name="Wallpaper library items">
                                <ItemsControl x:Name="LibraryList" ItemsSource="{Binding LibraryItems}" AutomationProperties.Name="Wallpaper library">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Tag="{Binding}" Click="WallpaperCard_Click" Padding="0" BorderThickness="0"
                                                    AutomationProperties.Name="{Binding AccessibleName}" Background="Transparent"
                                                    Width="246" Height="204" Margin="0,0,14,14"
                                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                                <Border x:Name="Card" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                    <Grid>
                                                        <Grid.RowDefinitions><RowDefinition Height="136" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                                        <Grid Background="#1B1B1D">
                                                            <Viewbox Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Path Data="M2,3 H18 V17 H2 Z M8,7 L14,10 L8,13 Z" Stroke="#6F6F74" Fill="Transparent" StrokeThickness="1.2" StrokeLineJoin="Round" />
                                                            </Viewbox>
                                                            <Border Background="#D91A1A1C" BorderBrush="#353538" BorderThickness="1" CornerRadius="4" Padding="7,3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                                                                <TextBlock Text="{Binding Kind}" FontSize="10" FontWeight="SemiBold" />
                                                            </Border>
                                                            <Border Background="#D947654A" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Visibility="{Binding IsPlaying, Converter={StaticResource BoolVisibility}}">
                                                                <TextBlock Text="PLAYING" FontSize="10" FontWeight="SemiBold" />
                                                            </Border>
                                                        </Grid>
                                                        <Grid Grid.Row="1" Margin="13,10">
                                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Row="1" Text="{Binding Meta}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0" />
                                                        </Grid>
                                                    </Grid>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#8B8B90" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border x:Name="EmptyState" Style="{StaticResource CardBorder}" BorderBrush="{StaticResource StrongBorderBrush}"
                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="510" Margin="12" Padding="42">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="32" Background="#202022" HorizontalAlignment="Center">
                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="M2,3 H18 V17 H2 Z M8,7 L14,10 L8,13 Z" Stroke="#A8A8AC" Fill="Transparent" StrokeThickness="1.2" StrokeLineJoin="Round" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="Add your first wallpaper" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,18,0,0" />
                                    <TextBlock Text="Drop an MP4, WebM, MKV, or MOV video here, or choose a file."
                                               Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" Width="370" Margin="0,7,0,18" FontSize="13" />
                                    <Button Content="Choose a wallpaper" Style="{StaticResource AccentButton}" Click="AddWallpaper_Click" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Editor -->
                    <Grid x:Name="EditorPage" Margin="30,24,30,26" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Button Content="‹  Library" Click="BackToLibrary_Click" Padding="12,7" />
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock x:Name="EditorTitle" Text="Select a wallpaper" FontSize="21" FontWeight="SemiBold" />
                                <TextBlock x:Name="EditorSubtitle" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="EditorPreviewColumn" Width="1.7*" />
                                <ColumnDefinition x:Name="EditorGapColumn" Width="16" />
                                <ColumnDefinition x:Name="EditorOptionsColumn" Width="0.92*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardBorder}" Padding="0" ClipToBounds="True" Background="#050506">
                                    <Grid>
                                        <Rectangle Fill="#050506" />
                                        <MediaElement x:Name="VideoPreview" LoadedBehavior="Manual" UnloadedBehavior="Manual" Stretch="UniformToFill"
                                                      ScrubbingEnabled="True" MediaOpened="VideoPreview_MediaOpened" MediaFailed="VideoPreview_MediaFailed" />
                                        <StackPanel x:Name="PreviewPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Viewbox Width="38" Height="38"><Path Data="M2,3 H18 V17 H2 Z M8,7 L14,10 L8,13 Z" Stroke="#6F6F74" Fill="Transparent" StrokeThickness="1.2" /></Viewbox>
                                            <TextBlock Text="Preview unavailable" Foreground="{StaticResource MutedBrush}" Margin="0,9,0,0" FontSize="13" />
                                        </StackPanel>
                                        <Border VerticalAlignment="Bottom" Background="#E0101011" BorderBrush="#303033" BorderThickness="0,1,0,0" Padding="14,9">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <Button x:Name="PreviewPlayButton" Content="Pause" Click="PreviewPlayButton_Click" Padding="11,6" />
                                                <Slider x:Name="PreviewPosition" Grid.Column="1" Margin="13,0" Minimum="0" Maximum="1" ValueChanged="PreviewPosition_ValueChanged" AutomationProperties.Name="Preview position" />
                                                <TextBlock x:Name="PreviewTimeText" Grid.Column="2" Text="00:00 / 00:00" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="11" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,14,0,0" Padding="18,14">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Loop segment" FontWeight="SemiBold" />
                                            <Border HorizontalAlignment="Right" Background="#252527" CornerRadius="4" Padding="8,3">
                                                <TextBlock x:Name="SegmentLengthText" Text="Full video" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                            </Border>
                                        </Grid>
                                        <controls:RangeSelector x:Name="SegmentSelector" Margin="0,8,0,2" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="START" Foreground="{StaticResource SubtleBrush}" FontSize="10" FontWeight="SemiBold" Margin="1,0,0,5" />
                                                <TextBox x:Name="StartTimeBox" Text="00:00.000" LostKeyboardFocus="TimeBox_LostKeyboardFocus" AutomationProperties.Name="Segment start time" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="END" Foreground="{StaticResource SubtleBrush}" FontSize="10" FontWeight="SemiBold" Margin="1,0,0,5" />
                                                <TextBox x:Name="EndTimeBox" Text="00:00.000" LostKeyboardFocus="TimeBox_LostKeyboardFocus" AutomationProperties.Name="Segment end time" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Column="2" Style="{StaticResource InvisibleScrollViewer}"
                                          AutomationProperties.Name="Wallpaper options"
                                          AutomationProperties.AutomationId="OptionsScroller">
                                <StackPanel>
                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Playback" FontWeight="SemiBold" />
                                            <TextBlock Text="Audio" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,17,0,7" />
                                            <CheckBox x:Name="AudioSwitch" Style="{StaticResource ToggleSwitch}" Content="Play video audio" Checked="AudioSwitch_Changed" Unchecked="AudioSwitch_Changed" />
                                            <TextBlock Text="Volume" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,16,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="40" /></Grid.ColumnDefinitions>
                                                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="50" ValueChanged="VolumeSlider_ValueChanged" AutomationProperties.Name="Wallpaper volume" />
                                                <TextBlock x:Name="VolumeText" Grid.Column="1" Text="50%" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Target" FontWeight="SemiBold" />
                                            <TextBlock Text="DISPLAY" Foreground="{StaticResource SubtleBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,15,0,5" />
                                            <Border Background="#111112" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="11">
                                                <StackPanel>
                                                    <TextBlock Text="All displays" FontWeight="SemiBold" FontSize="12" />
                                                    <TextBlock Text="Spans the virtual desktop" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="Fill screen · center crop · never stretched" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="1,8,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="File" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FilePathText" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,10,0,0" />
                                            <Button Content="Remove from library" Click="RemoveWallpaper_Click" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Button x:Name="ApplyButton" Content="Apply wallpaper" Click="ApplyWallpaper_Click" Margin="0,14,0,0" />
                                    <Button x:Name="StopButton" Content="Stop current wallpaper" Click="StopWallpaper_Click" Margin="0,8,0,0" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- Settings -->
                    <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" Style="{StaticResource InvisibleScrollViewer}" AutomationProperties.Name="Settings page">
                        <StackPanel Margin="38,28" MaxWidth="760" HorizontalAlignment="Left">
                            <TextBlock Text="Settings" FontSize="27" FontWeight="SemiBold" />
                            <TextBlock Text="Startup and background playback." Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,6,0,22" />

                            <Border Style="{StaticResource CardBorder}" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Start wallpaper with Windows" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="Starts only the native host, not this controller window." Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="StartWithWindowsSwitch" Grid.Column="1" Style="{StaticResource ToggleSwitch}" Checked="StartWithWindows_Changed" Unchecked="StartWithWindows_Changed" AutomationProperties.Name="Start wallpaper with Windows" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Background host" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock x:Name="HostDetailsText" Text="Stopped" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="ExitHostButton" Content="Exit host" Click="ExitHost_Click" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Storage" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock x:Name="DataPathText" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,7,0,12" TextWrapping="Wrap" />
                                    <Button Content="Open data folder" Click="OpenDataFolder_Click" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="About LiveWallpaper" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Text="Native C++ playback host · Windows Media Foundation" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,7,0,0" />
                                    <TextBlock Text="Version 1.0.0" Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="Toast" Background="#F2242426" BorderBrush="{StaticResource StrongBorderBrush}" BorderThickness="1" CornerRadius="7"
                            Padding="14,9" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" Visibility="Collapsed" Panel.ZIndex="20">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Ellipse x:Name="ToastDot" Width="7" Height="7" Fill="{StaticResource SuccessBrush}" Margin="0,0,9,0" />
                            <TextBlock x:Name="ToastText" Grid.Column="1" FontSize="12" FontWeight="SemiBold" AutomationProperties.LiveSetting="Assertive" />
                            <Button Grid.Column="2" Content="×" Margin="12,-5,-6,-5" Padding="7,3" BorderThickness="0" Background="Transparent" Click="DismissToast_Click" AutomationProperties.Name="Dismiss notification" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
